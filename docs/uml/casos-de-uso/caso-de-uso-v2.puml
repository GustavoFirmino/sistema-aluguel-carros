@startuml caso-de-uso-v2
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #EEF5FF
skinparam usecaseBorderColor #336699
skinparam ArrowColor #336699

title Sistema de Aluguel de Carros — Diagrama de Casos de Uso (Sprint 03)

actor Cliente
actor "Agente\n(Empresa)" as Empresa
actor "Agente\n(Banco)" as Banco

rectangle "Sistema de Aluguel de Carros" {

  ' ── Cliente ─────────────────────────────────────────────
  usecase "UC01 — Cadastrar cliente\n(com empregadores)" as UC1
  usecase "UC02 — Atualizar dados cadastrais" as UC2
  usecase "UC03 — Consultar automóveis disponíveis" as UC3
  usecase "UC04 — Criar pedido de aluguel" as UC4
  usecase "UC05 — Consultar status do pedido" as UC5
  usecase "UC06 — Cancelar pedido (PENDENTE)" as UC6

  ' ── Agente (Empresa) ────────────────────────────────────
  usecase "UC07 — Assumir análise do pedido\n(mover para EM_ANALISE)" as UC7
  usecase "UC08 — Aprovar pedido" as UC8
  usecase "UC09 — Rejeitar pedido" as UC9
  usecase "UC10 — Gerar contrato de aluguel" as UC10
  usecase "UC11 — Cadastrar agente" as UC11

  ' ── Agente (Banco) ──────────────────────────────────────
  usecase "UC12 — Associar contrato de crédito bancário" as UC12
}

' ── Associações ─────────────────────────────────────────
Cliente --> UC1
Cliente --> UC2
Cliente --> UC3
Cliente --> UC4
Cliente --> UC5
Cliente --> UC6

Empresa --> UC7
Empresa --> UC8
Empresa --> UC9
Empresa --> UC10
Empresa --> UC11

Banco --> UC11
Banco --> UC12

' ── Relações entre UCs ──────────────────────────────────
UC8 .> UC7 : <<include>>
UC9 .> UC7 : <<include>>
UC10 .> UC8 : <<include>>
UC12 .> UC10 : <<extend>>

@enduml
