@startuml caso-de-uso-v3
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #EEF5FF
skinparam usecaseBorderColor #336699
skinparam ArrowColor #336699

title Sistema de Aluguel de Carros — Diagrama de Casos de Uso (Sprint 03 — Revisado)

actor "Cliente"              as Cliente
actor "Banco\n(Agente)"      as Banco
actor "Empresa\n(Agente)"    as Empresa
actor "Administrador\n(Admin/Agente)" as Admin

rectangle "Sistema de Aluguel de Carros" {

  ' ── Público / Autenticação ──────────────────────────────
  usecase "UC01 — Criar conta de cliente\n(auto-login após cadastro)" as UC1
  usecase "UC02 — Realizar login"                                      as UC2
  usecase "UC03 — Realizar logout"                                     as UC3

  ' ── Cliente ─────────────────────────────────────────────
  usecase "UC04 — Completar perfil\n(renda mensal + banco parceiro)"   as UC4
  usecase "UC05 — Consultar frota disponível"                          as UC5
  usecase "UC06 — Criar pedido de aluguel"                             as UC6
  usecase "UC07 — Acompanhar status do pedido"                         as UC7
  usecase "UC08 — Cancelar pedido (apenas PENDENTE)"                   as UC8

  ' ── Banco ───────────────────────────────────────────────
  usecase "UC09 — Visualizar pedidos pendentes\ndo seu banco"          as UC9
  usecase "UC10 — Aprovar pedido\n(PENDENTE → APROVADO_BANCO)"         as UC10
  usecase "UC11 — Rejeitar pedido\n(PENDENTE → REJEITADO)"             as UC11

  ' ── Empresa ─────────────────────────────────────────────
  usecase "UC12 — Visualizar pedidos aprovados pelo banco"             as UC12
  usecase "UC13 — Gerar contrato de aluguel\n(APROVADO_BANCO → CONCLUIDO)" as UC13
  usecase "UC14 — Rejeitar pedido aprovado"                            as UC14

  ' ── Admin / Agente ──────────────────────────────────────
  usecase "UC15 — CRUD de Clientes"                                    as UC15
  usecase "UC16 — CRUD de Automóveis"                                  as UC16
  usecase "UC17 — CRUD de Agentes\n(Banco e Empresa)"                  as UC17
  usecase "UC18 — Visualizar todos os pedidos\n(Dashboard + listagem)" as UC18
  usecase "UC19 — Atualizar status de qualquer pedido"                 as UC19
  usecase "UC20 — Visualizar todos os contratos"                       as UC20
}

' ── Associações ─────────────────────────────────────────
Cliente  --> UC1
Cliente  --> UC2
Cliente  --> UC3
Cliente  --> UC4
Cliente  --> UC5
Cliente  --> UC6
Cliente  --> UC7
Cliente  --> UC8

Banco    --> UC2
Banco    --> UC3
Banco    --> UC5
Banco    --> UC9
Banco    --> UC10
Banco    --> UC11

Empresa  --> UC2
Empresa  --> UC3
Empresa  --> UC5
Empresa  --> UC12
Empresa  --> UC13
Empresa  --> UC14
Empresa  --> UC20

Admin    --> UC2
Admin    --> UC3
Admin    --> UC15
Admin    --> UC16
Admin    --> UC17
Admin    --> UC18
Admin    --> UC19
Admin    --> UC20

' ── Relações entre UCs ──────────────────────────────────
UC6  .> UC4  : <<include>>
UC6  .> UC5  : <<include>>
UC10 .> UC9  : <<include>>
UC11 .> UC9  : <<include>>
UC13 .> UC12 : <<include>>
UC14 .> UC12 : <<include>>

@enduml
